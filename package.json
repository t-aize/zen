{
  "name": "zen",
  "version": "1.0.0",
  "description": "Production-grade Discord bot monorepo.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --if-present --parallel dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "format": "pnpm -r --if-present format",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "prisma:generate": "pnpm --filter bot prisma:generate",
    "prisma:migrate": "pnpm --filter bot prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter bot prisma:migrate:deploy",
    "prisma:studio": "pnpm --filter bot prisma:studio",
    "prisma:format": "pnpm --filter bot prisma:format",
    "prisma:validate": "pnpm --filter bot prisma:validate",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@swc/core": "^1.15.32",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
