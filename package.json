{
	"name": "zen",
	"version": "0.1.0",
	"description": "One bot. Full stack. Open-source. Self-hostable. A unified, multilingual Discord bot platform with moderation, tickets, music, levels, anti-raid, and a web dashboard.",
	"private": true,
	"type": "module",
	"license": "Apache-2.0",
	"author": "t-aize",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/t-aize/zen.git"
	},
	"bugs": {
		"url": "https://github.com/t-aize/zen/issues"
	},
	"homepage": "https://github.com/t-aize/zen#readme",
	"keywords": [
		"discord",
		"bot",
		"moderation",
		"tickets",
		"music",
		"levels",
		"anti-raid",
		"automod",
		"dashboard",
		"self-hosted",
		"open-source",
		"multilingual",
		"i18n"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2024 --outfile=dist/index.js --packages=external --tree-shaking=true --sourcemap --legal-comments=none",
		"start": "node dist/index.js",
		"type-check": "tsc --noEmit",
		"lint:fix": "biome check --write src",
		"clean": "rimraf dist .tsbuildinfo",
		"prepare": "husky"
	},
	"dependencies": {
		"@discordjs/voice": "^0.19.0",
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^25.3.2",
		"discord-api-types": "^0.38.40",
		"esbuild": "^0.27.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"pino-pretty": "^13.1.3",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.ts": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
