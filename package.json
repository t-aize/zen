{
	"name": "zen",
	"version": "0.1.0",
	"description": "One bot. Full stack. Open-source. Self-hostable. A unified, multilingual Discord bot platform with moderation, tickets, music, levels, anti-raid, and a web dashboard.",
	"private": true,
	"type": "module",
	"license": "Apache-2.0",
	"author": "t-aize",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/t-aize/zen.git"
	},
	"bugs": {
		"url": "https://github.com/t-aize/zen/issues"
	},
	"homepage": "https://github.com/t-aize/zen#readme",
	"keywords": [
		"discord",
		"bot",
		"moderation",
		"tickets",
		"music",
		"levels",
		"anti-raid",
		"automod",
		"dashboard",
		"self-hosted",
		"open-source",
		"multilingual",
		"i18n"
	],
	"engines": {
		"node": ">=25",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2024 --outfile=dist/index.js --packages=external --tree-shaking=true --legal-comments=none --minify",
		"start": "node dist/index.js",
		"type-check": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"clean": "rimraf dist .tsbuildinfo",
		"prepare": "husky"
	},
	"dependencies": {
		"@discordjs/voice": "^0.19.2",
		"discord.js": "^14.26.2",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"optionalDependencies": {
		"bufferutil": "^4.1.0",
		"zlib-sync": "^0.1.10"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"discord-api-types": "^0.38.45",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.27.7",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.2",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.1"
	},
	"lint-staged": {
		"*.{ts,mts,cts,js,mjs,cjs}": [
			"eslint --fix --max-warnings=0",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
