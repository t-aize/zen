# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Discord application client ID.
DISCORD_CLIENT_ID=

# Optional guild ID for fast development slash-command registration.
DISCORD_DEV_GUILD_ID=

# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zen?schema=public

# Runtime environment: dev, prod, or test.
NODE_ENV=dev

# Pino log level: fatal, error, warn, info, debug, trace, or silent.
LOG_LEVEL=info
