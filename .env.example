NODE_ENV=development
LOG_LEVEL=info

# Discord Developer Portal > Application > Bot
DISCORD_TOKEN=replace_me

# Discord Developer Portal > Application > General Information
DISCORD_CLIENT_ID=replace_me

# Optional, but strongly recommended in development.
# If set, slash commands are deployed to one guild instantly.
# If empty, slash commands are deployed globally and can take time to appear.
DISCORD_GUILD_ID=
