# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zen
POSTGRES_DB=zen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─── Logging ──────────────────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
